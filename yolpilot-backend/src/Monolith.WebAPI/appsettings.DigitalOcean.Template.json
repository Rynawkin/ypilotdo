{
  "Database": {
    "Provider": "Postgres",
    "UseSnakeCase": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_HOST;Port=25060;Database=YOUR_DB;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true;"
  },
  "Routing": {
    "MatrixProvider": "Osrm",
    "EnableGoogleFallback": true,
    "Google": {
      "MaxBatchSize": 10,
      "MaxRouteCoordinatesPerRequest": 25
    },
    "Osrm": {
      "BaseUrl": "http://YOUR_OSRM_HOST:5000",
      "Profile": "driving"
    }
  }
}
